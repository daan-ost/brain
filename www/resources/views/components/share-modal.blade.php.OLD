<!-- QRCode Library -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js" integrity="sha512-CNgIRecGo7nphbeZ04Sc13ka07paqdeTu0WR1IM4kNcpmBAUSHSQX0FslNhTDadL4O5SAGapGt4FodqL8My0mA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

<!-- Extended Share Modal Component -->
<div x-data="shareModalComponent()"
     x-show="$store.shareModal.isOpen"
     x-cloak
     @keydown.escape.window="$store.shareModal.close()"
     class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50"
     style="display: none;">

    <div class="relative top-10 mx-auto p-6 border w-full max-w-2xl shadow-lg rounded-lg bg-white my-8">
        <!-- Close button -->
        <button @click="$store.shareModal.close()"
                class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>

        <!-- Title -->
        <h2 class="text-2xl font-semibold text-gray-900 mb-6">
            {{ __('ui.share_file') }}
        </h2>

        <!-- Share Stats (if exists and > 0) -->
        <div x-show="shareData.access_count !== undefined && shareData.access_count > 0" class="mb-6 grid grid-cols-2 gap-4">
            <div class="bg-blue-50 p-4 rounded-lg">
                <div class="text-sm text-blue-600 font-medium">{{ __('ui.total_views') }}</div>
                <div class="text-2xl font-bold text-blue-900" x-text="shareData.access_count || 0"></div>
            </div>
            <div class="bg-green-50 p-4 rounded-lg">
                <div class="text-sm text-green-600 font-medium">{{ __('ui.last_accessed') }}</div>
                <div class="text-sm font-medium text-green-900" x-text="shareData.last_accessed_at || '{{ __('ui.never') }}'"></div>
            </div>
        </div>

        <!-- Share Link Input + Copy Button -->
        <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-2">{{ __('ui.share_link') }}</label>
            <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                <div class="flex-1 flex items-center px-4 py-3 bg-gray-50">
                    <svg class="w-5 h-5 text-gray-400 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
                        <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
                    </svg>
                    <input type="text"
                           x-model="$store.shareModal.shareUrl"
                           readonly
                           class="flex-1 bg-transparent border-0 focus:ring-0 text-sm text-gray-700 px-0 cursor-text"
                           @click="$event.target.select()">
                </div>
                <button @click="copyToClipboard()"
                        class="px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-medium text-sm transition flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                    </svg>
                    <span x-show="!copied">{{ __('ui.copy') }}</span>
                    <span x-show="copied">{{ __('ui.copied') }}</span>
                </button>
            </div>
            <p x-show="copied"
               x-transition
               class="mt-2 text-sm text-green-600 flex items-center gap-1">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {{ __('ui.link_copied_to_clipboard') }}
            </p>
        </div>

        <!-- Two Column Layout: QR Code + Actions -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- QR Code Section -->
            <div class="text-center p-4 bg-gray-50 rounded-lg">
                <h3 class="text-sm font-semibold text-gray-900 mb-3">
                    {{ __('ui.scan_to_download') }}
                </h3>
                <div class="flex justify-center mb-3">
                    <div id="qrcode" class="inline-block p-3 bg-white border-2 border-gray-200 rounded-lg"></div>
                </div>
                <p class="text-xs text-gray-500">
                    {{ __('ui.scan_qr_code_description') }}
                </p>
            </div>

            <!-- Actions Section -->
            <div class="space-y-3">
                <h3 class="text-sm font-semibold text-gray-900 mb-3">
                    {{ __('ui.share_options') }}
                </h3>

                <!-- Share Status -->
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                    <div class="flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full"
                             :class="shareData.is_active ? 'bg-green-500' : 'bg-red-500'"></div>
                        <span class="text-sm font-medium text-gray-700">
                            {{ __('ui.share_status') }}
                        </span>
                    </div>
                    <span class="text-sm font-semibold"
                          :class="shareData.is_active ? 'text-green-600' : 'text-red-600'"
                          x-text="shareData.is_active ? '{{ __('ui.active') }}' : '{{ __('ui.disabled') }}'">
                    </span>
                </div>

                <!-- Expiration Info -->
                <div x-show="shareData.expires_at" class="flex items-start gap-2 p-3 bg-yellow-50 rounded-lg">
                    <svg class="w-5 h-5 text-yellow-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <div class="flex-1">
                        <div class="text-xs font-medium text-yellow-800">{{ __('ui.expires_at') }}</div>
                        <div class="text-sm text-yellow-900" x-text="shareData.expires_at"></div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="space-y-2 pt-2">
                    <!-- Refresh Stats Button -->
                    <button @click="refreshShareData()"
                            class="w-full flex items-center justify-center gap-2 px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                        </svg>
                        {{ __('ui.refresh_stats') }}
                    </button>

                    <!-- Revoke/Disable Button -->
                    <button @click="revokeShare()"
                            x-show="shareData.is_active"
                            class="w-full flex items-center justify-center gap-2 px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path>
                        </svg>
                        {{ __('ui.disable_share') }}
                    </button>

                    <!-- Re-enable Button -->
                    <button @click="enableShare()"
                            x-show="!shareData.is_active"
                            class="w-full flex items-center justify-center gap-2 px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        {{ __('ui.enable_share') }}
                    </button>
                </div>
            </div>
        </div>

        <!-- Email Share Section -->
        <div class="mt-6 pt-6 border-t border-gray-200">
            <h3 class="text-sm font-semibold text-gray-900 mb-3 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                {{ __('ui.send_via_email') }}
            </h3>

            <!-- Email Form -->
            <form @submit.prevent="sendEmail()" x-show="!emailSent" class="space-y-4">
                <!-- Recipient Email -->
                <div>
                    <label for="recipient_email" class="block text-sm font-medium text-gray-700 mb-1">
                        {{ __('ui.recipient_email') }} <span class="text-red-500">*</span>
                    </label>
                    <input type="email"
                           id="recipient_email"
                           x-model="emailForm.recipient_email"
                           required
                           placeholder="name@example.com"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm text-gray-900"
                           :disabled="emailSending">
                </div>

                <!-- Sender Name -->
                <div>
                    <label for="sender_name" class="block text-sm font-medium text-gray-700 mb-1">
                        {{ __('ui.your_name') }} <span class="text-gray-400 text-xs">({{ __('ui.optional') }})</span>
                    </label>
                    <input type="text"
                           id="sender_name"
                           x-model="emailForm.sender_name"
                           maxlength="255"
                           placeholder="{{ __('ui.your_name_placeholder') }}"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm text-gray-900"
                           :disabled="emailSending">
                </div>

                <!-- Personal Message -->
                <div>
                    <label for="personal_message" class="block text-sm font-medium text-gray-700 mb-1">
                        {{ __('ui.personal_message') }} <span class="text-gray-400 text-xs">({{ __('ui.optional') }})</span>
                    </label>
                    <textarea id="personal_message"
                              x-model="emailForm.personal_message"
                              maxlength="500"
                              rows="3"
                              placeholder="{{ __('ui.personal_message_placeholder') }}"
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm text-gray-900 resize-none"
                              :disabled="emailSending"></textarea>
                    <div class="flex justify-between items-center mt-1">
                        <p class="text-xs text-gray-500">
                            <span x-text="emailForm.personal_message.length"></span>/500
                        </p>
                        <p class="text-xs text-gray-500">
                            {{ __('ui.emails_sent_count') }}: <span x-text="shareData.share_email_sent_count || 0"></span>/5
                        </p>
                    </div>
                </div>

                <!-- Privacy Notice -->
                <div class="flex items-start gap-2 p-3 bg-blue-50 rounded-lg">
                    <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <p class="text-xs text-blue-800">
                        {{ __('ui.email_privacy_notice') }}
                    </p>
                </div>

                <!-- Error Message -->
                <div x-show="emailError"
                     x-transition
                     class="flex items-start gap-2 p-3 bg-red-50 rounded-lg">
                    <svg class="w-5 h-5 text-red-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <div class="flex-1">
                        <p class="text-sm text-red-800" x-text="emailError"></p>
                        <p x-show="emailWaitSeconds"
                           class="text-xs text-red-600 mt-1">
                            {{ __('ui.please_wait') }} <span x-text="emailWaitSeconds"></span> {{ __('ui.seconds') }}
                        </p>
                    </div>
                </div>

                <!-- Send Button -->
                <button type="submit"
                        :disabled="emailSending || !shareData.is_active"
                        class="w-full flex items-center justify-center gap-2 px-4 py-3 bg-indigo-600 hover:bg-indigo-700 disabled:bg-gray-400 disabled:cursor-not-allowed text-white font-medium text-sm rounded-lg transition">
                    <svg x-show="emailSending" class="animate-spin h-4 w-4" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <svg x-show="!emailSending" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                    </svg>
                    <span x-show="emailSending">{{ __('ui.sending') }}</span>
                    <span x-show="!emailSending">{{ __('ui.send_email') }}</span>
                </button>

                <p x-show="!shareData.is_active" class="text-xs text-red-600 text-center">
                    {{ __('ui.share_link_not_active') }}
                </p>
            </form>

            <!-- Success Message -->
            <div x-show="emailSent"
                 x-transition
                 class="space-y-4">
                <div class="flex items-start gap-3 p-4 bg-green-50 rounded-lg">
                    <svg class="w-6 h-6 text-green-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <div class="flex-1">
                        <p class="text-sm font-medium text-green-800">{{ __('ui.email_sent_successfully') }}</p>
                        <p class="text-xs text-green-600 mt-1">
                            {{ __('ui.emails_sent_count') }}: <span x-text="shareData.share_email_sent_count || 0"></span>
                        </p>
                    </div>
                </div>

                <button @click="resetEmailForm()"
                        class="w-full flex items-center justify-center gap-2 px-4 py-2 border border-gray-300 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    {{ __('ui.send_another_email') }}
                </button>
            </div>
        </div>
    </div>
</div>

<script>
// Register Alpine.js store for share modal
document.addEventListener('alpine:init', () => {
    Alpine.store('shareModal', {
        isOpen: false,
        shareUrl: '',
        data: {},

        open(shareUrl, data = {}) {
            console.log('[ShareModal] Opening with URL:', shareUrl, 'Data:', data);
            this.shareUrl = shareUrl;
            this.data = data;
            this.isOpen = true;
        },

        close() {
            console.log('[ShareModal] Closing');
            this.isOpen = false;
            this.shareUrl = '';
            this.data = {};
        }
    });
});

function shareModalComponent() {
    return {
        copied: false,
        shareData: {},
        emailForm: {
            recipient_email: '',
            sender_name: '{{ auth()->user()->name ?? "" }}',
            personal_message: ''
        },
        emailSending: false,
        emailSent: false,
        emailError: '',
        emailWaitSeconds: null,

        init() {
            console.log('[ShareModalComponent] Initialized');

            // Watch for modal open
            this.$watch('$store.shareModal.isOpen', (isOpen) => {
                if (isOpen) {
                    this.copied = false;
                    this.shareData = this.$store.shareModal.data || {};
                    this.resetEmailForm();

                    // Generate QR code on next tick
                    this.$nextTick(() => {
                        this.generateQRCode(this.$store.shareModal.shareUrl);
                    });
                } else {
                    // Clear QR code when modal closes
                    this.clearQRCode();
                    this.shareData = {};
                    this.resetEmailForm();
                }
            });
        },

        async copyToClipboard() {
            try {
                await navigator.clipboard.writeText(this.$store.shareModal.shareUrl);
                this.copied = true;
                setTimeout(() => this.copied = false, 3000);
            } catch (err) {
                console.error('Failed to copy:', err);
                this.fallbackCopy();
            }
        },

        fallbackCopy() {
            const input = document.createElement('input');
            input.value = this.$store.shareModal.shareUrl;
            input.style.position = 'fixed';
            input.style.left = '-9999px';
            document.body.appendChild(input);
            input.select();
            document.execCommand('copy');
            document.body.removeChild(input);
            this.copied = true;
            setTimeout(() => this.copied = false, 3000);
        },

        async refreshShareData() {
            if (!this.shareData.batch_id) return;

            try {
                const response = await fetch(`/share/create/${this.shareData.batch_id}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content
                    }
                });

                const data = await response.json();
                if (data.success) {
                    this.shareData = data;
                    this.$store.shareModal.data = data;
                }
            } catch (error) {
                console.error('Failed to refresh share data:', error);
            }
        },

        async revokeShare() {
            if (!this.shareData.batch_id) return;

            if (!confirm('{{ __('ui.confirm_disable_share') }}')) return;

            try {
                const response = await fetch(`/share/revoke/${this.shareData.batch_id}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content
                    }
                });

                const data = await response.json();
                if (data.success) {
                    this.shareData.is_active = false;
                    alert('{{ __('ui.share_disabled_success') }}');
                }
            } catch (error) {
                console.error('Failed to revoke share:', error);
                alert('{{ __('ui.share_disable_error') }}');
            }
        },

        async enableShare() {
            // Re-enable is same as creating new share
            await this.refreshShareData();
        },

        generateQRCode(url) {
            const qrcodeContainer = document.getElementById('qrcode');
            if (!qrcodeContainer) return;

            this.clearQRCode();

            if (typeof QRCode === 'undefined') {
                console.error('QRCode library not loaded');
                qrcodeContainer.innerHTML = '<p class="text-red-500 text-sm">QR code library not loaded</p>';
                return;
            }

            try {
                new QRCode(qrcodeContainer, {
                    text: url,
                    width: 160,
                    height: 160,
                    colorDark: "#000000",
                    colorLight: "#ffffff",
                    correctLevel: QRCode.CorrectLevel.M
                });
            } catch (error) {
                console.error('Failed to generate QR code:', error);
                qrcodeContainer.innerHTML = '<p class="text-red-500 text-sm">Failed to generate QR code</p>';
            }
        },

        clearQRCode() {
            const qrcodeContainer = document.getElementById('qrcode');
            if (qrcodeContainer) {
                qrcodeContainer.innerHTML = '';
            }
        },

        async sendEmail() {
            if (!this.shareData.batch_id) {
                this.emailError = '{{ __('ui.batch_not_found') }}';
                return;
            }

            if (!this.shareData.is_active) {
                this.emailError = '{{ __('ui.share_link_not_active') }}';
                return;
            }

            // Reset errors
            this.emailError = '';
            this.emailWaitSeconds = null;
            this.emailSending = true;

            try {
                const response = await fetch(`/share/send-email/${this.shareData.batch_id}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content
                    },
                    body: JSON.stringify({
                        recipient_email: this.emailForm.recipient_email,
                        sender_name: this.emailForm.sender_name,
                        personal_message: this.emailForm.personal_message
                    })
                });

                const data = await response.json();

                if (data.success) {
                    // Update share data with new counters
                    this.shareData.share_email_sent_count = data.total_sent;
                    this.emailSent = true;
                    this.emailError = '';
                } else {
                    // Handle errors
                    this.emailError = data.error || '{{ __('ui.failed_to_send_email') }}';

                    // Handle rate limit with wait time
                    if (data.reason === 'rate_limit' && data.wait_seconds) {
                        this.emailWaitSeconds = data.wait_seconds;
                    }
                }
            } catch (error) {
                console.error('Failed to send email:', error);
                this.emailError = '{{ __('ui.failed_to_send_email') }}';
            } finally {
                this.emailSending = false;
            }
        },

        resetEmailForm() {
            this.emailForm = {
                recipient_email: '',
                sender_name: '{{ auth()->user()->name ?? "" }}',
                personal_message: ''
            };
            this.emailSending = false;
            this.emailSent = false;
            this.emailError = '';
            this.emailWaitSeconds = null;
        }
    }
}
</script>
