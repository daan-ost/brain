# =============================================================================
# Application
# =============================================================================

APP_NAME=Basewebsite
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://yourapp:8890

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# =============================================================================
# Branding / Company
# =============================================================================

APP_PRODUCT_NAME="Your Product"
APP_LOGO_URL=""
APP_COMPANY_NAME="Your Company"
APP_COMPANY_ADDRESS="Amsterdam, Netherlands"

# =============================================================================
# Database
# =============================================================================

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=8889
DB_DATABASE=yourapp
DB_USERNAME=root
DB_PASSWORD=root

# =============================================================================
# Session
# =============================================================================

SESSION_DRIVER=file
SESSION_LIFETIME=10080
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# =============================================================================
# Cache, Queue, Filesystem
# =============================================================================

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# =============================================================================
# Logging
# =============================================================================

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# Mail
# =============================================================================

MAIL_SEND_REAL=false
MAIL_MAILER=log
MAIL_FROM_ADDRESS=info@example.com
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# Postmark (Transactional Email)
# =============================================================================
# Get tokens from https://account.postmarkapp.com/servers

POSTMARK_TOKEN=
POSTMARK_STAGING_SERVER_TOKEN=
POSTMARK_PROD_SERVER_TOKEN=
POSTMARK_STAGING_SERVER_ID=
POSTMARK_PROD_SERVER_ID=
POSTMARK_FROM_EMAIL=info@example.com

# Message Streams
POSTMARK_STREAM_TRANSACTIONAL=outbound
POSTMARK_STREAM_BROADCAST=broadcast

# Webhook Secrets (generate at Postmark > Webhooks)
POSTMARK_WEBHOOK_SECRET=
POSTMARK_INBOUND_SECRET=

# =============================================================================
# Mollie (Payments)
# =============================================================================
# Get keys from https://www.mollie.com/dashboard/developers/api-keys

MOLLIE_API_KEY=
MOLLIE_WEBHOOK_URL=
MOLLIE_PROFILE_ID=
MOLLIE_WEBHOOK_IPS=87.233.217.110,87.233.217.111,87.233.217.242,87.233.217.243

# =============================================================================
# Stripe (Payments)
# =============================================================================
# Get keys from https://dashboard.stripe.com/apikeys
# Webhook secret from https://dashboard.stripe.com/webhooks

STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_URL=

# Payment provider routing (mollie | stripe)
# Default: mollie — per License te overschrijven via licenses.payment_provider
PAYMENT_DEFAULT_PROVIDER=mollie

# =============================================================================
# DeepL (Translations)
# =============================================================================
# Shared development key — get your own at https://www.deepl.com/pro-api

DEEPL_API_KEY=
DEEPL_FORMALITY=prefer_more
DEEPL_GLOSSARY_EN_NL=
TRANSLATE_DEFAULT_FROM=en
TRANSLATE_TARGETS=nl
TRANSLATE_EXCLUDE_FIELDS=slug,handle,id,template,blueprint

# =============================================================================
# IPRegistry (Geolocation)
# =============================================================================

IPREGISTRY_SECRET=
IPREGISTRY_API_URL=

# =============================================================================
# Invoice / Billing
# =============================================================================

INVOICE_COMPANY_NAME="Your Company"
INVOICE_COMPANY_LEGAL_NAME="Your Company"
INVOICE_COMPANY_ADDRESS="Your Address"
INVOICE_COMPANY_POSTAL_CODE="1234 AB"
INVOICE_COMPANY_CITY="Amsterdam"
INVOICE_COMPANY_COUNTRY="The Netherlands"
INVOICE_COMPANY_VAT_ID=
INVOICE_COMPANY_COC=
INVOICE_COMPANY_EMAIL=info@example.com
INVOICE_COMPANY_PHONE="+31 20 123 4567"
INVOICE_COMPANY_WEBSITE=www.example.com
INVOICE_COMPANY_IBAN=
INVOICE_COMPANY_BIC=
INVOICE_DEFAULT_DUE_DAYS=14

# VAT
TAX_AMOUNT=21

# =============================================================================
# SEO
# =============================================================================

SEO_COMPANY_LATITUDE=52.3676
SEO_COMPANY_LONGITUDE=4.9041

# =============================================================================
# Analytics & Tracking
# =============================================================================

GA4_MEASUREMENT_ID=
META_PIXEL_ID=
HOTJAR_SITE_ID=

# =============================================================================
# AWS (optional)
# =============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================================
# Nieuwsbrief (Amazon SES)
# =============================================================================

AWS_SES_REGION=eu-west-1
SES_CONFIGURATION_SET=newsletter-tracking
SES_TRACKING_DOMAIN=

NEWSLETTER_FROM_ADDRESS=
NEWSLETTER_FROM_NAME=
NEWSLETTER_BATCH_SIZE=100
NEWSLETTER_BATCH_DELAY=10
NEWSLETTER_BRAND_COLOR=#53b3ae

# =============================================================================
# Redis (optional — not used by default)
# =============================================================================

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# External APIs (optional)
# =============================================================================

GEMINI_API_KEY=

# =============================================================================
# Vite
# =============================================================================

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# Feature Flags
# =============================================================================

FEATURE_DEMO_CRUD=false

# =============================================================================
# Security / Proxy
# =============================================================================
# In production: set to your load balancer/CDN IPs (comma-separated)
# Example for Cloudflare:
# TRUSTED_PROXIES=173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,141.101.64.0/18,108.162.192.0/18,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17,162.158.0.0/15,104.16.0.0/13,104.24.0.0/14,172.64.0.0/13,131.0.72.0/22

#TRUSTED_PROXIES=

# =============================================================================
# Data Retention
# =============================================================================

STORAGE_RETENTION_DAYS=14

# Google OAuth (Socialite)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# =============================================================================
# Sentry — error monitoring + cron monitoring + release tracking
# =============================================================================
# Get DSN from https://sentry.io/settings/{org}/projects/{project}/keys/
# Leave empty locally — Sentry sends nothing without a DSN (no noise during dev)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false
SENTRY_ENVIRONMENT="${APP_ENV}"
SENTRY_RELEASE=

# =============================================================================
# Trustpilot — Automatic Feedback Service (AFS)
# =============================================================================
# Get the AFS email from Trustpilot Business → Collect reviews → Automatic
# Leave empty to disable Trustpilot review invitations after purchase
TRUSTPILOT_AFS_EMAIL=
